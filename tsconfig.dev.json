{
    "extends": "./tsconfig.base.json",
    "compilerOptions": {
        "module": "ES2020",
        "moduleResolution": "bundler",
        "verbatimModuleSyntax": true,
        "isolatedModules": true,
        "rootDir": "src",
        "outDir": "dist",
        "sourceMap": true,
        "types": ["node", "jest"]
    },
    "include": ["src/**/*"],
    "exclude": ["node_modules", "dist"]
}
